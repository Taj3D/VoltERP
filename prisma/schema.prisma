  transactionCode String   @unique
  bankId          String
  date            DateTime
  type            String   // "Deposit", "Withdraw", "Transfer"
  amount          Float
  runningBalance  Float    @default(0)
  toBankId        String?  // For bank-to-bank transfers
  companyId       String?  // Multi-tenant isolation
  chequeNo        String?  // Cheque number reference
  depositorName   String?  // Name of the depositor
  referenceNo     String?  // Reference/comment for the transaction
  description     String?
  status          String   @default("Approved")
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  bank            Bank     @relation(fields: [bankId], references: [id])
  toBank          Bank?    @relation("TransferToBank", fields: [toBankId], references: [id])
  company         Company? @relation(fields: [companyId], references: [id])

  @@index([bankId])
  @@index([companyId])
  @@index([date])
  @@index([type])
}

// ============================================================
// SMS SERVICE
// ============================================================

model SmsSetting {
  id              String   @id @default(cuid())
  apiUrl          String
  apiKey          String
  senderId        String
  maskingName     String?  // Registered masking sender name
  maskingRegId    String?  // Masking registration tracking ID
  gatewayName     String?  // Carrier/gateway provider name (e.g., "BulkSMSBD", "Infobip")
  ratePerSms      Float    @default(0)  // Per-SMS cost in BDT
  unicodeRate     Float    @default(0)  // Per-Unicode-SMS cost in BDT
  setupCost             Float    @default(0)  // Gateway one-time setup cost
  creditBalanceLimit    Float    @default(0)  // SMS API credit balance alert threshold (BDT)
  lastKnownCreditBalance Float   @default(0)  // Last fetched gateway credit balance
  companyId             String?  // Multi-tenant isolation
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model SmsLog {
  id              String   @id @default(cuid())
  recipient        String
  message          String
  charCount        Int      @default(0)  // Character count of the message
  smsSegmentCount  Int      @default(1)  // Number of SMS segments (ceil(charCount/160) or ceil(charCount/70) for Unicode)
  isUnicode        Boolean  @default(false)  // Whether message contains Unicode/Bangla characters
  status           String   @default("Pending")  // "Pending", "Sent", "Delivered", "Failed"
  gatewayResponse  String?  // Raw response from SMS gateway
  sentAt           DateTime @default(now())
  cost             Float    @default(0)
  campaignName     String?  // Name of the bulk campaign (if part of one)
  companyId        String?  // Multi-tenant isolation
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company          Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([status])
  @@index([sentAt])
}

model SmsBill {
  id              String          @id @default(cuid())
  period          String
  totalSms        Int             @default(0)
  totalSegments   Int             @default(0)  // Total SMS segments billed
  totalCost       Float           @default(0)
  paidAmount      Float           @default(0)
  outstanding     Float           @default(0)  // totalCost - paidAmount
  status          String          @default("Unpaid")  // "Unpaid", "Partial", "Paid"
  companyId       String?         // Multi-tenant isolation
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  company         Company?        @relation(fields: [companyId], references: [id])
  payments        SmsBillPayment[]

  @@index([companyId])
  @@index([status])
}

model SmsBillPayment {
  id        String   @id @default(cuid())
  smsBillId String
  amount    Float
  date      DateTime
  method    String?  // "Cash", "Bank Transfer", "Mobile Banking", "Cheque"
  reference String?  // Payment reference/transaction ID
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  smsBill   SmsBill  @relation(fields: [smsBillId], references: [id])

  @@index([smsBillId])
}

// ============================================================
// SMS AUTOMATION CONFIG — Block 12, Directive 3
// Transactional Auto-SMS Engine global Boolean toggle flags
// ============================================================

model SmsAutomationConfig {
  id                     String   @id @default(cuid())
  smsAlertOnPurchase     Boolean  @default(false)  // TRIGGER A: Product Purchase Alert
  smsAlertOnCollection   Boolean  @default(false)  // TRIGGER B: Cash/Bank/MFS Collection Alert
  smsAlertOnStockReceive Boolean  @default(false)  // TRIGGER C: Warehouse Stock Receipt Notification
  smsAlertOnHrLifecycle  Boolean  @default(false)  // TRIGGER D: HR Recruitment & Joining Lifecycle Alerts
  companyId              String?  // Multi-tenant isolation
  isActive               Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  company                Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

// ============================================================
// CHART OF ACCOUNTS & GENERAL LEDGER
// ============================================================

model ChartOfAccount {
  id                  String           @id @default(cuid())
  code                String           @unique  // COA-XXXXX
  name                String
  classification      String           @default("Asset")  // "Asset", "Liability", "Income", "Expense", "Equity"
  parentAccountId     String?
  openingBalance      Float            @default(0)
  openingBalanceType  String           @default("Dr")  // "Dr" or "Cr"
  companyId           String?          // Multi-tenant isolation
  isActive            Boolean          @default(true)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  parentAccount       ChartOfAccount?  @relation("COAHierarchy", fields: [parentAccountId], references: [id])
  childAccounts       ChartOfAccount[] @relation("COAHierarchy")
  ledgerEntries       LedgerEntry[]
  company             Company?         @relation(fields: [companyId], references: [id])
  customers           Customer[]       // Customer sub-nodes under AR
  suppliers           Supplier[]       // Supplier sub-nodes under AP

  @@index([companyId])
}

model LedgerEntry {
  id              String        @id @default(cuid())
  entryCode       String        @unique  // LED-XXXXX
  date            DateTime
  accountId       String?
  account         String
  particulars     String?
  debit           Float         @default(0)
  credit          Float         @default(0)
  reference       String?
  referenceType   String?       // "SalesOrder", "PurchaseOrder", "Expense", "Income", "CashCollection", "CashDelivery", "BankTransaction", "Manual"
  companyId       String?       // Multi-tenant isolation
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  chartOfAccount  ChartOfAccount? @relation(fields: [accountId], references: [id])
  company         Company?      @relation(fields: [companyId], references: [id])

  @@index([accountId])
  @@index([date])
  @@index([referenceType])
  @@index([companyId])
}

// ============================================================
// PERIOD CLOSE (Month-End Closing Validation Locks)
// ============================================================

model PeriodClose {
  id          String   @id @default(cuid())
  code        String   @unique  // BAL-XXXXX
  periodMonth Int
  periodYear  Int
  closeDate   DateTime
  closedBy    String?
  isLocked    Boolean  @default(false)
  notes       String?
  companyId   String?  // Multi-tenant isolation
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company         Company?      @relation(fields: [companyId], references: [id])

  @@unique([periodMonth, periodYear])
  @@index([companyId])
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id          String   @id @default(cuid())
  action      String   // "CREATE", "UPDATE", "DELETE", "LOGIN", "LOGOUT", "EXPORT", "IMPORT"
  module      String   // "Products", "PurchaseOrders", "SalesOrders", etc.
  recordId    String?  // ID of the affected record
  recordLabel String?  // Human-readable label for the record
  userId      String?  // Who performed the action
  userName    String?  // Display name of the user
  details     String?  // JSON string with before/after data
  ip          String?
  companyId   String?  // Multi-tenant isolation for audit trail
  userAgent   String?  // Browser/client user-agent string
  createdAt   DateTime @default(now())

  @@index([module])
  @@index([action])
  @@index([createdAt])
  @@index([userId])
  @@index([companyId])
}

// ============================================================
// DOMAIN 20: SYSTEM AUDIT LOGS, BACKUPS & SECURITY OVERHAUL
// ============================================================

// SystemAuditLog — Immutable, append-only deep-diff audit trail
// Captures complete before/after state for every mutation across all 20 domains
model SystemAuditLog {
  id              String   @id @default(cuid())
  actorUserId     String?  // User who performed the action
  companyId       String?  // Multi-tenant isolation
  ipAddress       String?  // Client IP address
  userAgent       String?  // Browser/client user-agent
  actionType      String   // "CREATE", "UPDATE", "DELETE"
  targetModel     String   // Prisma model name (e.g., "Product", "SalesOrder", "Bank")
  targetRecordId  String?  // ID of the affected record
  previousState   String?  // JSON string — deep-diff of record BEFORE mutation (masked)
  newState        String?  // JSON string — deep-diff of record AFTER mutation (masked)
  metadata        String?  // Additional context (module token, request path, etc.)
  createdAt       DateTime @default(now())

  @@index([actorUserId])
  @@index([companyId])
  @@index([actionType])
  @@index([targetModel])
  @@index([createdAt])
}

// SystemBackup — Multi-tenant backup tracking and S3-compatible vault
model SystemBackup {
  id              String   @id @default(cuid())
  backupCode      String   @unique  // BKP-XXXXX
  companyId       String?  // Multi-tenant isolation
  triggeredBy     String?  // User ID who initiated the backup
  triggeredByName String?  // Display name
  status          String   @default("PENDING")  // "PENDING", "ENCRYPTING", "UPLOADING", "COMPLETED", "FAILED"
  backupType      String   @default("FULL")  // "FULL", "INCREMENTAL"
  recordCount     Int      @default(0)  // Number of records exported
  fileSizeBytes   Int      @default(0)  // Size of the encrypted dump
  storageKey      String?  // S3-compatible object storage key
  checksumSha256  String?  // SHA-256 checksum for integrity verification
  errorMessage    String?  // Error details if status = "FAILED"
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
  @@index([backupType])
}

// RateLimitAttempt — In-memory sliding window rate limiter tracking
model RateLimitAttempt {
  id          String   @id @default(cuid())
  ipAddress   String   // Client IP address
  endpoint    String   // Target endpoint (e.g., "/api/auth/login")
  success     Boolean  @default(false)  // Whether the attempt succeeded
  userAgent   String?  // Browser/client user-agent
  createdAt   DateTime @default(now())

  @@index([ipAddress])
  @@index([endpoint])
  @@index([createdAt])
}

// ============================================================
// GROUP 5: FINANCIAL AUDITING, AUTOMATED LEDGERS & DATA INTEGRITY
// ============================================================

// Notification Engine — threshold alerts for low-stock, out-of-balance, overdue installments
model Notification {
  id           String   @id @default(cuid())
  code         String   @unique  // NOT-XXXXX
  type         String   // "LowStock", "OverdueInstallment", "BalanceMismatch", "PeriodClose", "DataIntegrity", "System"
  severity     String   @default("Info")  // "Info", "Warning", "Critical"
  title        String
  message      String
  module       String?  // "SalesOrder", "PurchaseOrder", "Stock", "Ledger", etc.
  referenceId  String?  // ID of the related record
  referenceCode String? // Human-readable code (PO-00001, SO-00001, etc.)
  companyId    String?  // Multi-tenant isolation
  isRead       Boolean  @default(false)
  isDismissed  Boolean  @default(false)
  dismissedAt  DateTime?
  dismissedBy  String?
  actionUrl    String?  // Navigation hint for frontend
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  company      Company? @relation(fields: [companyId], references: [id])

  @@index([type])
  @@index([isRead])
  @@index([createdAt])
  @@index([companyId])
}

// Product Serial/IMEI Lifecycle Tracking — trace full history from procurement to sale/return
model ProductSerialTracking {
  id              String   @id @default(cuid())
  code            String   @unique  // SRL-XXXXX
  productId       String
  serialNumber    String?  // Serial number
  imeiNumber      String?  // IMEI number (for mobile devices)
  status          String   @default("InStock")  // "InStock", "Sold", "Returned", "Replaced", "Damaged", "Transferred"
  purchaseOrderId String?  // Original procurement source
  salesOrderId    String?  // Sale record
  godownId        String?  // Current warehouse location
  customerId      String?  // Current owner (if sold)
  supplierId      String?  // Original supplier
  companyId       String?  // Multi-tenant isolation
  purchaseDate    DateTime?
  saleDate        DateTime?
  returnDate      DateTime?
  warrantyExpiry  DateTime?
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

// Data Integrity Audit Log — out-of-balance entries, reconciliation failures
model DataIntegrityLog {
  id              String   @id @default(cuid())
  code            String   @unique  // DIL-XXXXX
  checkType       String   // "LedgerBalance", "StockReconciliation", "PeriodIntegrity", "VATReconciliation", "AccountConsistency"
  status          String   @default("Passed")  // "Passed", "Failed", "Warning"
  module          String?  // Module being checked
  details         String?  // JSON string with check details
  discrepancy     Float    @default(0)  // Amount of imbalance if any
  expectedValue   Float    @default(0)
  actualValue     Float    @default(0)
  companyId       String?  // Multi-tenant isolation
  checkedAt       DateTime @default(now())
  checkedBy       String?
  resolvedAt      DateTime?
  resolvedBy      String?
  resolution      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

// Ledger Auto-Post Queue — tracks automatic ledger entries generated from transactions
model LedgerAutoPost {
  id              String   @id @default(cuid())
  code            String   @unique  // LAP-XXXXX
  sourceType      String   // "SalesOrder", "PurchaseOrder", "Expense", "Income", "CashCollection", "CashDelivery", "BankTransaction", "HireSales", "SalesReturn", "PurchaseReturn"
  sourceId        String   // ID of the source transaction
  sourceCode      String?  // Human-readable reference (invoice no, PO no, etc.)
  debitEntryId    String?  // LED-XXXXX of the debit entry
  creditEntryId   String?  // LED-XXXXX of the credit entry
  debitAccount    String   // Account name debited
  creditAccount   String   // Account name credited
  amount          Float    @default(0)
  postingDate     DateTime
  status          String   @default("Posted")  // "Pending", "Posted", "Reversed", "Failed"
  companyId       String?  // Multi-tenant isolation — inherited from source document
  reversalReason  String?
  postedAt        DateTime @default(now())
  postedBy        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  company         Company? @relation(fields: [companyId], references: [id])

  @@index([sourceType])
  @@index([postingDate])
  @@index([status])
  @@index([companyId])
}

// ============================================================
// GROUP 6: CORE PERFORMANCE CONFIGURATIONS & SYSTEM SETTINGS
// ============================================================

// System Configuration — global app settings, company branding, tax/VAT rates, currency, printer
model SystemConfig {
  id                    String   @id @default(cuid())
  configKey             String   @unique  // Unique key like "company_name", "default_vat_rate", "currency_symbol"
  configValue           String   // JSON-encoded value
  configType            String   @default("string")  // "string", "number", "boolean", "json"
  category              String   @default("General")  // "General", "Tax", "Currency", "Printer", "Branding", "Email"
  description           String?  // Human-readable description
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([category])
  @@index([configType])
}

// Invoice Template — HTML templates for invoice generation, email notifications
model InvoiceTemplate {
  id                String   @id @default(cuid())
  code              String   @unique  // TPL-XXXXX
  name              String   // "Sales Invoice", "Purchase Invoice", "Hire Receipt", "Credit Memo", "Debit Note", "Email Notification"
  templateType      String   @default("Invoice")  // "Invoice", "Receipt", "Email", "CreditMemo", "DebitNote", "Statement"
  subject           String?  // Email subject line (for email templates)
  headerHtml        String?  // HTML header content (logo, company info)
  bodyHtml          String?  // HTML body template with {{placeholders}}
  footerHtml        String?  // HTML footer content (terms, bank details)
  cssStyles         String?  // Custom CSS for the template
  paperSize         String   @default("A4")  // "A4", "Letter", "Legal"
  orientation       String   @default("Portrait")  // "Portrait", "Landscape"
  defaultPrinter       String?  // Printer name/dimension config
  // Header overrides
  companyName          String?  // Override company name on invoice (if different from Company.name)
  showLogo             Boolean  @default(true)  // Whether to show logo on invoice
  showBrandLogo        Boolean  @default(false) // Whether to show brand logo
  showMobile           Boolean  @default(true)  // Whether to show mobile on header
  showAddress          Boolean  @default(true)  // Whether to show address on header
  showVatNumber        Boolean  @default(false) // Whether to show VAT number
  showTradeLicense     Boolean  @default(false) // Whether to show trade license
  // Metadata grid fields
  showCustomerCode     Boolean  @default(true)  // Show Customer Code field
  showPrevDue          Boolean  @default(true)  // Show Previous Due field
  showTotalDue         Boolean  @default(true)  // Show Total Due field
  showRemindDate       Boolean  @default(true)  // Show Remind Date field
  // Table columns
  showModel            Boolean  @default(true)  // Show Model column
  showColor            Boolean  @default(true)  // Show Color column
  showDescription      Boolean  @default(true)  // Show Description column
  showMRP              Boolean  @default(true)  // Show MRP column
  showDiscountAmt      Boolean  @default(true)  // Show Discount Amount column
  showUnitPrice        Boolean  @default(true)  // Show Unit Price column
  // Summary section
  showDiscountPct      Boolean  @default(true)  // Show Discount % row
  showPPDiscount       Boolean  @default(true)  // Show PP Discount row
  showAdjustment       Boolean  @default(true)  // Show Adjustment row
  showDeliveryCost     Boolean  @default(true)  // Show Delivery Cost row
  // Payment details
  showPaymentDetails   Boolean  @default(true)  // Show Payment Details section
  // Footer
  showCustomerSignature Boolean @default(true)  // Show Customer's Signature
  showPreparedBy        Boolean @default(true)  // Show Prepared By
  showCheckedBy         Boolean @default(true)  // Show Checked By
  showAuthorizedBy      Boolean @default(true)  // Show Authorized By
  showPrintedBy         Boolean @default(true)  // Show Printed By
  showSalesPerson       Boolean @default(true)  // Show Sales Person
  showPrintDate         Boolean @default(true)  // Show Print Date
  // Custom terms/notes
  termsAndConditions    String?  // Custom terms & conditions text
  customFooterNote      String?  // Custom footer note (overrides system note)
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Number Format — prefix/padding configuration for all document codes
model NumberFormat {
  id                String   @id @default(cuid())
  code              String   @unique  // NF-XXXXX
  moduleKey         String   @unique  // "purchase_order", "sales_order", "hire_sales", "sales_return", "purchase_return", "replacement", "transfer", "expense", "income", "cash_collection", "cash_delivery", "bank_transaction", "ledger_entry", "journal_entry"
  prefix            String   // "PUR-", "SO-", "HIR-", "SRT-", "PRT-", "RPL-", "TRF-", "EXP-", "INC-", "CC-", "CD-", "BT-", "LED-", "JRN-"
  paddingLength     Int      @default(5)  // Zero-padded length (e.g., 5 = 00001)
  nextSequence      Int      @default(1)  // Auto-incrementing counter
  resetYearly       Boolean  @default(false)  // Reset counter at fiscal year start
  separator         String?  // Optional separator between prefix and number (default: none)
  dateFormat        String?  // Optional date format to embed in code
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
