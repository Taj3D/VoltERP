generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTHENTICATION
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("admin")
  companyId String?  // Multi-tenant isolation: links user to a company
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company? @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

// ============================================================
// INVESTMENT MODULE
// ============================================================

model InvestmentHead {
  id              String       @id @default(cuid())
  code            String       @unique
  name            String
  description     String?
  type            String       @default("Liability") // "Liability", "Asset", "Investment"
  openingBalance  Float        @default(0)
  openingType     String       @default("")
  sharePercentage Float?       // Share ownership percentage for equity heads
  capitalValue    Float?       // Capital value of the investment head
  companyId       String?      // Multi-tenant isolation
  profileImage    String?      // Profile photo (base64 or URL)
  nidFrontImage   String?      // National ID front card image
  nidBackImage    String?      // National ID back card image
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  company         Company?     @relation(fields: [companyId], references: [id])
  assets          Asset[]
  liabilities     Liability[]

  @@index([companyId])
}

model Asset {
  id                String            @id @default(cuid())
  investmentHeadId  String
  date              DateTime
  amount            Float             // Purchase value / capital injection amount
  assetCategory     String            @default("Fixed") // "Fixed" or "Current"
  purchaseValue     Float             @default(0) // Original purchase/acquisition value (Fixed assets)
  salvageValue      Float             @default(0) // Estimated salvage/residual value at end of useful life
  usefulLifeMonths  Int               @default(0) // Useful life in months for depreciation calculation
  depreciationRate  Float             @default(0) // Annual depreciation rate (%)
  accumulatedDepreciation Float       @default(0) // Running accumulated depreciation
  netBookValue      Float             @default(0) // Current net book value (purchaseValue - accumulatedDepreciation)
  idempotencyKey    String?           @unique // Idempotent reference key to prevent duplicate asset allocation
  description       String?
  companyId         String?           // Multi-tenant isolation
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  investmentHead    InvestmentHead    @relation(fields: [investmentHeadId], references: [id])
  company           Company?          @relation(fields: [companyId], references: [id])
  depreciationSchedules AssetDepreciation[]

  @@index([investmentHeadId])
  @@index([companyId])
  @@index([assetCategory])
}

model AssetDepreciation {
  id              String     @id @default(cuid())
  assetId         String
  periodDate      DateTime   // The accounting period date (typically month-end)
  depreciationAmount Float   @default(0) // Depreciation amount for this period
  accumulatedDepreciation Float @default(0) // Running total accumulated depreciation after this entry
  netBookValue    Float      @default(0) // Net book value after this period's depreciation
  method          String     @default("StraightLine") // "StraightLine" or "DecliningBalance"
  notes           String?
  isActive        Boolean    @default(true)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  asset           Asset      @relation(fields: [assetId], references: [id])

  @@index([assetId])
  @@index([periodDate])
}

model Liability {
  id              String         @id @default(cuid())
  investmentHeadId String
  date            DateTime
  amount          Float
  type            String         @default("received") // "received" or "pay"
  paymentMethod   String?        // "Cash", "Bank Transfer", "Cheque", etc.
  description     String?
  companyId       String?        // Multi-tenant isolation
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  investmentHead  InvestmentHead @relation(fields: [investmentHeadId], references: [id])
  company         Company?       @relation(fields: [companyId], references: [id])

  @@index([investmentHeadId])
  @@index([companyId])
}

// ============================================================
// BASIC MODULES (SYSTEM SETUP)
// ============================================================

model Company {
  id          String        @id @default(cuid())
  code        String        @unique
  name        String
  address     String?
  phone       String?
  email       String?
  logo        String?       // Company logo - base64 data URL for multi-tenant persistence
  brandLogo   String?       // Brand logo image (high-res base64)
  logoData    String?       // High-density base64 binary storage for company logo (multi-tenant safe, no filesystem dependency)
  mobile      String?       // Primary mobile number for invoices
  website     String?       // Company website
  vatNumber   String?       // VAT/Tax registration number (BIN/TIN)
  tradeLicense String?      // Trade license number
  binNumber   String?       // Business Identification Number
  currencySymbol String?    @default("৳")  // Currency symbol for invoices and financial documents
  invoicePrefix String?     // Prefix for invoice numbers (e.g., "EM")
  thankYouMsg  String?      @default("Thank You Come Again.") // Customizable footer message
  systemNote   String?      @default("This is a system generated invoice no need to seal & signature.") // System generation note
  showBarcode  Boolean      @default(true)  // Whether to show barcode on invoices
  showPayInWord Boolean     @default(true)  // Whether to show amount in words
  logoWidth    Float        @default(30)    // Logo width in mm for PDF rendering
  logoHeight   Float        @default(20)    // Logo height in mm for PDF rendering
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  products           Product[]
  orderSheets        OrderSheet[]
  users              User[]
  banks              Bank[]
  expenseIncomeHeads ExpenseIncomeHead[]
  expenses           Expense[]
  incomes            Income[]
  cashCollections    CashCollection[]
  cashDeliveries     CashDelivery[]
  bankTransactions   BankTransaction[]
  smsSettings        SmsSetting[]
  smsLogs            SmsLog[]
  smsBills           SmsBill[]
  smsAutomationConfigs SmsAutomationConfig[]
  chartOfAccounts    ChartOfAccount[]
  ledgerEntries      LedgerEntry[]
  periodCloses       PeriodClose[]
  notifications      Notification[]
  dataIntegrityLogs  DataIntegrityLog[]
  ledgerAutoPosts    LedgerAutoPost[]
  productSerialTrackings ProductSerialTracking[]
  customers          Customer[]
  suppliers          Supplier[]
  salesOrders        SalesOrder[]
  purchaseOrders     PurchaseOrder[]
  hireSales          HireSales[]
  salesReturns       SalesReturn[]
  purchaseReturns    PurchaseReturn[]
  srTargetSetups     SRTargetSetup[]
  paymentOptions     PaymentOption[]
  investmentHeads    InvestmentHead[]
  assetEntries       Asset[]
  liabilityEntries   Liability[]
}

model Category {
  id               String    @id @default(cuid())
  code             String    @unique
  name             String
  description      String?
  parentCategoryId String?
  isActive         Boolean   @default(true)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  parent           Category? @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id])
  children         Category[] @relation("CategoryHierarchy")
  products         Product[]
}

model Color {
  id         String   @id @default(cuid())
  name       String
  colorCode  String
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  products   Product[]
}

model Bank {
  id             String            @id @default(cuid())
  bankName       String
  branch         String?
  accountNo      String
  accountHolder  String
  openingBalance Float             @default(0)
  currentBalance Float             @default(0)
  companyId      String?            // Multi-tenant isolation
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  company        Company?          @relation(fields: [companyId], references: [id])
  bankTransactions BankTransaction[]
  transferToTransactions BankTransaction[] @relation("TransferToBank")
  expenses      Expense[]
  incomes       Income[]
  cashCollections CashCollection[]
  cashDeliveries CashDelivery[]

  @@index([companyId])
}

model Department {
  id          String       @id @default(cuid())
  name        String
  description String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  designations Designation[]
  employees   Employee[]
}

model Godown {
  id        String   @id @default(cuid())
  name      String
  address   String?
  inCharge String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  products       Product[]
  purchaseOrders PurchaseOrder[]
  salesOrders    SalesOrder[]
  hireSales      HireSales[]
  salesReturns   SalesReturn[]
  transferFrom   StockTransfer[] @relation("TransferFrom")
  transferTo     StockTransfer[] @relation("TransferTo")
}

model InterestPercentage {
  id            String   @id @default(cuid())
  percentage    Float
  effectiveDate DateTime
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Segment {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]
}

model Capacity {
  id          String   @id @default(cuid())
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Brand {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]
}

model Unit {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  symbol      String?  // e.g., "pcs", "kg", "m", "l"
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SRTargetSetup {
  id          String   @id @default(cuid())
  employeeId  String
  month       Int
  year        Int
  targetAmount Float
  companyId   String?  // Multi-tenant isolation
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  employee    Employee @relation(fields: [employeeId], references: [id])
  company     Company? @relation(fields: [companyId], references: [id])

  @@index([employeeId])
  @@index([companyId])
}

model PaymentOption {
  id            String          @id @default(cuid())
  name          String
  companyId     String?         // Multi-tenant isolation
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  company       Company?        @relation(fields: [companyId], references: [id])
  cardTypeSetups CardTypeSetup[]
  expenses      Expense[]
  incomes       Income[]
  salesOrders   SalesOrder[]
  cashCollections CashCollection[]
  cashDeliveries CashDelivery[]

  @@index([companyId])
}

model CardType {
  id            String          @id @default(cuid())
  name          String
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  cardTypeSetups CardTypeSetup[]
}

model CardTypeSetup {
  id              String        @id @default(cuid())
  paymentOptionId String
  cardTypeId      String
  chargePercentage Float        @default(0)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  paymentOption   PaymentOption @relation(fields: [paymentOptionId], references: [id])
  cardType        CardType      @relation(fields: [cardTypeId], references: [id])

  @@index([paymentOptionId])
  @@index([cardTypeId])
}

// ============================================================
// PRODUCT MASTER
// ============================================================

model Product {
  id            String   @id @default(cuid())
  productCode   String   @unique
  name          String
  categoryId    String
  colorId       String?
  brandId       String?
  unit          String?
  sizeCapacity  String?
  costPrice     Float    @default(0)
  salePrice     Float    @default(0)
  wholesalePrice Float   @default(0)
  dealerPrice   Float    @default(0)
  openingStock  Float    @default(0)
  reorderLevel  Float    @default(0)
  godownId      String?
  segmentId     String?
  companyId     String?
  imeiNumber    String?
  image         String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  category      Category @relation(fields: [categoryId], references: [id])
  color         Color?   @relation(fields: [colorId], references: [id])
  brand         Brand?   @relation(fields: [brandId], references: [id])
  godown        Godown?  @relation(fields: [godownId], references: [id])
  segment       Segment? @relation(fields: [segmentId], references: [id])
  company       Company? @relation(fields: [companyId], references: [id])
  stockEntries       StockEntry[]
  poLines            PurchaseOrderLine[]
  salesLines         SalesOrderLine[]
  orderSheetLines    OrderSheetLine[]
  transferLines      StockTransferLine[]
  hireSalesLines     HireSalesLine[]
  replacementLines   ReplacementOrderLine[]
  salesReturnLines   SalesReturnLine[]
  purchaseReturnLines PurchaseReturnLine[]

  @@index([categoryId])
  @@index([brandId])
  @@index([godownId])
  @@index([companyId])
  @@index([isActive])
}

// ============================================================
// STAFF MANAGEMENT
// ============================================================

model Designation {
  id            String     @id @default(cuid())
  code          String     @unique  // DSG-XXXXX
  name          String
  departmentId  String
  gradeLevel    String?    // e.g. "Grade-1", "Grade-2", "Senior", "Junior"
  salaryBandMin Float      @default(0)
  salaryBandMax Float      @default(0)
  description   String?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  department    Department @relation(fields: [departmentId], references: [id])
  employees     Employee[]

  @@index([departmentId])
}

model Employee {
  id                 String          @id @default(cuid())
  employeeCode       String          @unique  // EMP-XXXXX
  name               String
  designationId      String
  departmentId       String
  joiningDate        DateTime
  baseSalary         Float           @default(0)
  employeeType       String          @default("Permanent")  // "Permanent", "Contract", "Probation", "Part-time"
  status             String          @default("Active")  // "Active", "On Leave", "Resigned", "Terminated"
  // Personal Info
  gender             String?         // "Male", "Female", "Other"
  bloodGroup         String?         // "A+", "A-", "B+", "B-", "O+", "O-", "AB+", "AB-"
  religion           String?
  dateOfBirth        DateTime?
  fatherName         String?
  motherName         String?
  spouseName         String?
  maritalStatus      String?         // "Single", "Married", "Divorced", "Widowed"
  nidNumber          String?         // National ID
  tinNumber          String?         // Tax Identification Number
  // Contact
  phone              String?
  email              String?
  presentAddress     String?
  permanentAddress   String?
  emergencyContact   String?
  emergencyContactName String?
  // Banking
  bankName           String?
  bankAccountNo      String?
  // Other
  photo              String?
  nidFrontImage      String?         // National ID front card image
  nidBackImage       String?         // National ID back card image
  referenceBy        String?
  address            String?
  isActive           Boolean         @default(true)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  designation        Designation     @relation(fields: [designationId], references: [id])
  department         Department      @relation(fields: [departmentId], references: [id])
  leaves             EmployeeLeave[]
  srTargets          SRTargetSetup[]

  @@index([designationId])
  @@index([departmentId])
  @@index([isActive])
}

model EmployeeLeave {
  id          String    @id @default(cuid())
  leaveCode   String    @unique  // LEV-XXXXX
  employeeId  String
  leaveType   String    // "Casual", "Sick", "Annual", "Maternity"
  fromDate    DateTime
  toDate      DateTime
  totalDays   Float     @default(0)
  reason      String?
  status      String    @default("Pending")  // "Pending", "Approved", "Rejected"
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  employee    Employee  @relation(fields: [employeeId], references: [id])

  @@index([employeeId])
  @@index([status])
}

// ============================================================
// CUSTOMERS & SUPPLIERS
// ============================================================

model Customer {
  id                String          @id @default(cuid())
  customerCode      String          @unique  // CUS-XXXXX
  name              String
  phone             String?         // Primary mobile — collision-shielded per tenant
  alternativePhone  String?         // Alternative phone — collision-shielded per tenant
  email             String?         // Email — collision-shielded per tenant
  address           String?
  area              String?
  reference         String?
  nidNumber         String?         // National ID / Tax ID — collision-shielded per tenant
  openingBalance    Float           @default(0)
  openingBalanceType String         @default("Dr")  // "Dr" (Due) or "Cr" (Advance)
  creditLimit       Float           @default(0)
  customerType      String          @default("Regular")  // "Regular" or "Dealer"
  profileImage      String?         // Profile photo (base64 or URL)
  nidFrontImage     String?         // National ID front card image
  nidBackImage      String?         // National ID back card image
  coaAccountId      String?         // Auto-mapped Chart of Accounts sub-node under Assets -> Accounts Receivable
  companyId         String?         // Multi-tenant isolation
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  company           Company?        @relation(fields: [companyId], references: [id])
  coaAccount        ChartOfAccount? @relation(fields: [coaAccountId], references: [id])
  salesOrders       SalesOrder[]
  hireSales         HireSales[]
  salesReturns      SalesReturn[]
  cashCollections   CashCollection[]
  orderSheets       OrderSheet[]

  @@index([companyId])
  @@index([coaAccountId])
}

model Supplier {
  id                 String           @id @default(cuid())
  supplierCode       String           @unique  // SUP-XXXXX
  name               String
  contactPerson      String?
  phone              String?          // Primary phone — collision-shielded per tenant
  alternativePhone   String?         // Alternative phone — collision-shielded per tenant
  email              String?          // Email — collision-shielded per tenant
  address            String?
  area               String?
  terms              String?          // Payment terms
  nidNumber          String?         // National ID / Tax ID — collision-shielded per tenant
  openingBalance     Float            @default(0)
  openingBalanceType String           @default("Cr")  // "Cr" (Due) or "Dr" (Advance)
  creditLimit        Float            @default(0)
  profileImage       String?          // Profile photo (base64 or URL)
  nidFrontImage      String?          // National ID front card image
  nidBackImage       String?          // National ID back card image
  coaAccountId       String?          // Auto-mapped Chart of Accounts sub-node under Liabilities -> Accounts Payable
  companyId          String?          // Multi-tenant isolation
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  company            Company?         @relation(fields: [companyId], references: [id])
  coaAccount         ChartOfAccount?  @relation(fields: [coaAccountId], references: [id])
  purchaseOrders     PurchaseOrder[]
  purchaseReturns    PurchaseReturn[]
  cashDeliveries     CashDelivery[]

  @@index([companyId])
  @@index([coaAccountId])
}

// ============================================================
// INVENTORY - ORDER SHEET & PURCHASE ORDER
// ============================================================

model OrderSheet {
  id          String           @id @default(cuid())
  sheetNo     String           @unique
  companyId   String?
  customerId  String?
  date        DateTime
  status      String           @default("Draft")
  notes       String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  company     Company?         @relation(fields: [companyId], references: [id])
  customer    Customer?        @relation(fields: [customerId], references: [id])
  lines       OrderSheetLine[]

  @@index([companyId])
  @@index([customerId])
  @@index([date])
  @@index([status])
}

model OrderSheetLine {
  id           String     @id @default(cuid())
  orderSheetId String
  productId    String
  quantity     Float
  rate         Float
  total        Float
  notes        String?
  orderSheet   OrderSheet @relation(fields: [orderSheetId], references: [id], onDelete: Cascade)
  product      Product    @relation(fields: [productId], references: [id])
}

model PurchaseOrder {
  id              String              @id @default(cuid())
  poNumber        String              @unique
  supplierId      String
  date            DateTime
  godownId        String?
  subTotal        Float               @default(0)
  discount        Float               @default(0)
  vatPercentage   Float               @default(0)
  vatAmount       Float               @default(0)
  grandTotal      Float               @default(0)
  status          String              @default("Draft")
  notes           String?
  companyId       String?             // Multi-tenant isolation
  isActive        Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  supplier        Supplier            @relation(fields: [supplierId], references: [id])
  godown          Godown?             @relation(fields: [godownId], references: [id])
  company         Company?            @relation(fields: [companyId], references: [id])
  lines           PurchaseOrderLine[]
  purchaseReturn  PurchaseReturn[]

  @@index([supplierId])
  @@index([godownId])
  @@index([date])
  @@index([status])
  @@index([companyId])
}

model PurchaseOrderLine {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Float
  rate            Float
  discountPercent Float         @default(0)
  discountAmount  Float         @default(0)
  vatAmount       Float         @default(0)
  total           Float
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id])
}

// ============================================================
// INVENTORY - SALES ORDER
// ============================================================

model SalesOrder {
  id              String           @id @default(cuid())
  invoiceNo       String           @unique
  customerId      String
  date            DateTime
  godownId        String?
  subTotal        Float            @default(0)
  discount        Float            @default(0)
  vatPercentage   Float            @default(0)
  vatAmount       Float            @default(0)
  grandTotal      Float            @default(0)
  paymentOptionId String?
  status          String           @default("Draft")
  notes           String?
  companyId       String?          // Multi-tenant isolation
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  customer        Customer         @relation(fields: [customerId], references: [id])
  godown          Godown?          @relation(fields: [godownId], references: [id])
  paymentOption   PaymentOption?   @relation(fields: [paymentOptionId], references: [id])
  company         Company?         @relation(fields: [companyId], references: [id])
  lines           SalesOrderLine[]
  salesReturns    SalesReturn[]
  replacements    ReplacementOrder[]

  @@index([customerId])
  @@index([godownId])
  @@index([date])
  @@index([status])
  @@index([companyId])
}

model SalesOrderLine {
  id              String      @id @default(cuid())
  salesOrderId    String
  productId       String
  quantity        Float
  rate            Float
  discountPercent Float       @default(0)
  discountAmount  Float       @default(0)
  vatAmount       Float       @default(0)
  total           Float
  salesOrder      SalesOrder  @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product         Product     @relation(fields: [productId], references: [id])
}

// ============================================================
// INVENTORY - HIRE SALES
// ============================================================

model HireSales {
  id                String          @id @default(cuid())
  invoiceNo         String          @unique
  customerId        String
  date              DateTime
  godownId          String?
  subTotal          Float           @default(0)
  downPayment       Float           @default(0)
  hireRate          Float           @default(0)
  duration          Int             @default(0)
  installmentAmount Float           @default(0)
  balanceAmount     Float           @default(0)
  totalPaid         Float           @default(0)
  currentStatus     String          @default("Active")
  nextPaymentDate   DateTime?
  returnDate        DateTime?
  grandTotal        Float           @default(0)
  vatPercentage     Float           @default(0)
  vatAmount         Float           @default(0)
  status            String          @default("Active")
  notes             String?
  companyId         String?         // Multi-tenant isolation
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  customer          Customer        @relation(fields: [customerId], references: [id])
  godown            Godown?         @relation(fields: [godownId], references: [id])
  company           Company?        @relation(fields: [companyId], references: [id])
  lines             HireSalesLine[]
  installments      HireInstallment[]

  @@index([customerId])
  @@index([date])
  @@index([status])
  @@index([companyId])
}

model HireSalesLine {
  id              String     @id @default(cuid())
  hireSalesId     String
  productId       String
  quantity        Float
  rate            Float
  discountPercent Float      @default(0)
