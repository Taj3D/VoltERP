{
  "framework": "nextjs",
  "buildCommand": "npx prisma generate && next build",
  "installCommand": "npm install --legacy-peer-deps",
  "regions": ["hnd1"],
  "functions": {
    "src/app/api/**/route.ts": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/dashboard-warmup",
      "schedule": "0 9 * * *"
    }
  ]
}
