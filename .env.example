# ============================================================
# VoltERP — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================================

# ── Database ──
# Option 1: Local SQLite (default, for development)
DATABASE_URL=file:./db/custom.db

# Option 2: Turso (cloud SQLite — for Vercel/production deployment)
# Sign up at https://turso.tech, create a database, then:
# DATABASE_URL=libsql://your-db-name-your-org.turso.io
# DATABASE_AUTH_TOKEN=your-turso-auth-token

# Option 3: PostgreSQL (alternative — for future migration)
# DATABASE_URL=postgresql://user:password@localhost:5432/volt-erp

# ── Authentication ──
# JWT secret — MUST be set in production (min 32 chars)
# Generate with: openssl rand -base64 48
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# ── Application ──
# NODE_ENV=production
# PORT=3000
