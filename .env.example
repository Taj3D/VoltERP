# VoltERP Environment Configuration
# Copy this file to .env and fill in your values

# Database — Local SQLite (default for development)
DATABASE_URL="file:./db/custom.db"
DIRECT_URL="file:./db/custom.db"

# Database — Turso (cloud SQLite for production/Vercel)
# Uncomment and fill these for Turso deployment:
# DATABASE_URL="libsql://your-db-name-your-org.aws-ap-northeast-1.turso.io"
# DIRECT_URL="libsql://your-db-name-your-org.aws-ap-northeast-1.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"

# JWT Authentication
JWT_SECRET="change-this-to-a-secure-random-string-in-production"

# Optional: Node environment
# NODE_ENV="production"

# ── Vercel Blob Storage (for company logos / brand images) ──
# Create a Blob store in Vercel dashboard → Storage → Create Blob Store
# Then copy the BLOB_READ_WRITE_TOKEN here and in Vercel env vars.
# When unset, the app falls back to storing logos as base64 in the database
# (works but slower — ~192KB per logo vs ~2KB CDN URL).
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxx"

# ── Cron Job Authentication ──
# Secret used by /api/dashboard-warmup endpoint to authenticate Vercel Cron
# requests. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# MUST be set identically in Vercel Project Settings → Environment Variables.
# Run `bun run scripts/setup-vercel-cron-secret.sh` to auto-generate + push.
CRON_SECRET="generate-a-64-char-hex-secret-here"

# ── Dashboard Audit Logging (performance) ──
# Set to "false" to skip fire-and-forget audit INSERTs on dashboard-batch
# calls (9 INSERTs per call compete with reads on libSQL HTTP client).
# Set to "true" to re-enable dashboard audit entries.
DASHBOARD_AUDIT_ENABLED="false"

# ── CSRF Enforcement ──
# Transitional mode (warning-only). Safe because JWT Bearer auth in
# Authorization header already prevents CSRF. Required for serverless
# (Vercel) and HMR (dev) where in-memory CSRF store doesn't persist.
CSRF_ENFORCE="false"
