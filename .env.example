# VoltERP Environment Configuration
# Copy this file to .env and fill in your values

# Database — Local SQLite (default for development)
DATABASE_URL="file:./db/custom.db"
DIRECT_URL="file:./db/custom.db"

# Database — Turso (cloud SQLite for production/Vercel)
# Uncomment and fill these for Turso deployment:
# DATABASE_URL="libsql://your-db-name-your-org.aws-ap-northeast-1.turso.io"
# DIRECT_URL="libsql://your-db-name-your-org.aws-ap-northeast-1.turso.io"
# DATABASE_AUTH_TOKEN="your-turso-auth-token"

# JWT Authentication
JWT_SECRET="change-this-to-a-secure-random-string-in-production"

# Optional: Node environment
# NODE_ENV="production"

# ── Vercel Blob Storage (for company logos / brand images) ──
# Create a Blob store in Vercel dashboard → Storage → Create Blob Store
# Then copy the BLOB_READ_WRITE_TOKEN here and in Vercel env vars.
# When unset, the app falls back to storing logos as base64 in the database
# (works but slower — ~192KB per logo vs ~2KB CDN URL).
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxx"
